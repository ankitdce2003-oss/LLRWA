# Copy this file to .env for local development. On Vercel, set these as
# real Environment Variables in the project's Settings instead — don't
# commit a real .env file.

# Generate with: openssl rand -hex 32
JWT_SECRET=

# Vercel injects this automatically once you add Postgres from the Storage
# tab and connect it to this project. For local development, point it at
# your own Postgres instance, e.g.:
# POSTGRES_URL=postgres://postgres:yourpassword@localhost:5432/llrwa
POSTGRES_URL=

PORT=3000
NODE_ENV=production
