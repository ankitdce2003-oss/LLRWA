# Copy this file to .env for local development. On Vercel, set these as
# real Environment Variables in the project's Settings instead — don't
# commit a real .env file.

# Generate with: openssl rand -hex 32
JWT_SECRET=

# Two shared access codes — anyone who has the right one can sign in for
# that role. Pick your own values (not the example words below).
STAFF_ACCESS_CODE=
CHECKER_ACCESS_CODE=

# Vercel injects this automatically once you connect a Postgres database
# from the Storage tab. For local development, point it at your own
# Postgres instance, e.g.:
# POSTGRES_URL=postgres://postgres:yourpassword@localhost:5432/llrwa
POSTGRES_URL=

PORT=3000
NODE_ENV=production
